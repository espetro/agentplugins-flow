{
  "name": "agentplugins-flow",
  "version": "1.0.0",
  "description": "Flow-state transitions for AI agents. Pi gets isolated subprocess flows with TUI; all other tier-1 harnesses get native subagent dispatch.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "agents/",
    "skills/",
    "agentplugins.config.ts",
    "README.md"
  ],
  "keywords": [
    "agentplugins",
    "flow",
    "subagent",
    "audit",
    "build",
    "debug",
    "scout",
    "pi-package",
    "opencode-plugin",
    "claude-code",
    "codex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/espetro/agentplugins-flow"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "agentplugins build && tsc",
    "build:pi": "tsc",
    "validate": "agentplugins validate",
    "lint": "agentplugins lint && tsc --noEmit",
    "test": "vitest run",
    "test:trace-ui": "vitest run tests/trace-first-invoke.test.ts tests/trace-render-state.test.ts tests/render-context-pipeline.test.ts tests/flow-live-state.test.ts tests/context-display.test.ts",
    "check:dist": "npm run build:pi && node scripts/check-dist.mjs",
    "sync:pi": "node scripts/sync-pi.mjs",
    "verify:pi": "npm run test:trace-ui && npm run sync:pi"
  },
  "devDependencies": {
    "@agentplugins/core": "^0.3.0",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": ">=0.37.0",
    "@earendil-works/pi-ai": ">=0.37.0",
    "@earendil-works/pi-coding-agent": ">=0.37.0",
    "@earendil-works/pi-tui": ">=0.37.0",
    "@sinclair/typebox": ">=0.34.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "dependencies": {
    "jsdom": "^29.1.0",
    "turndown": "^7.2.4"
  }
}
