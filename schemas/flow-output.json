{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlowStructuredOutput",
  "description": "Structured JSON output schema for pi-agent-flow flow responses. Flows append a ```json code block conforming to this schema at the end of their response.",
  "type": "object",
  "required": ["version", "status", "summary"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for forward compatibility.",
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "blocked", "failed"],
      "description": "Overall completion status."
    },
    "summary": {
      "type": "string",
      "description": "1-3 sentence summary of what was accomplished."
    },
    "files": {
      "type": "array",
      "description": "Files touched, read, or referenced.",
      "items": {
        "$ref": "#/definitions/FileEntry"
      }
    },
    "actions": {
      "type": "array",
      "description": "Actions performed or attempted.",
      "items": {
        "$ref": "#/definitions/Action"
      }
    },
    "commands": {
      "type": "array",
      "description": "Commands or tool calls executed during the flow.",
      "items": {
        "$ref": "#/definitions/CommandEntry"
      }
    },
    "notDone": {
      "type": "array",
      "description": "Incomplete, skipped, blocked, or deferred work.",
      "items": {
        "$ref": "#/definitions/NotDoneItem"
      }
    },
    "nextSteps": {
      "type": "array",
      "description": "Recommended next steps or follow-up flows.",
      "items": {
        "type": "string"
      }
    },
    "reasoning": {
      "type": "array",
      "description": "Reasoning chains, hypotheses, inferences made during the flow.",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "description": "Observations, warnings, caveats, side notes.",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "description": "Escape hatch for flow-specific data (audit findings, debug root cause, etc.)."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "FileEntry": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "description": "Path to the file, relative or absolute." },
        "role": {
          "type": "string",
          "enum": ["reference", "read", "modified", "created", "deleted", "test"],
          "description": "Semantic role of this file in the flow's work."
        },
        "description": { "type": "string", "description": "Why this file matters (1 sentence)." },
        "snippet": { "type": "string", "description": "Short excerpt or snippet (not full content)." },
        "ranges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "integer", "minimum": 1 },
              "end": { "type": "integer", "minimum": 1 },
              "label": { "type": "string", "description": "Free-form label like bug, fix, ref, added." }
            }
          }
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "string" },
        "result": {
          "type": "string",
          "enum": ["success", "failure", "partial", "skipped"]
        },
        "evidence": { "type": "string" }
      }
    },
    "CommandEntry": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string" },
        "tool": { "type": "string", "description": "Tool used: bash, grep, find, ls, batch, read, write, edit, flow, web." },
        "target": { "type": "string" },
        "result": {
          "type": "string",
          "enum": ["success", "failure", "partial", "aborted"]
        },
        "output": { "type": "string" },
        "purpose": { "type": "string" }
      }
    },
    "NotDoneItem": {
      "type": "object",
      "required": ["item"],
      "properties": {
        "item": { "type": "string" },
        "reason": { "type": "string" },
        "blocker": { "type": "string" },
        "nextStep": { "type": "string" }
      }
    }
  }
}
